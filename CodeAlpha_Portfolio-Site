<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Darshana K — Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Sora:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#080b14;--bg2:#0d1120;--bg3:#121826;
      --cyan:#00e5ff;--violet:#7c3aed;--pink:#e040fb;
      --white:#f0f4ff;--muted:#6b7a99;
      --border:rgba(0,229,255,.1);--card-bg:rgba(13,17,32,.7);
      --glow:0 0 30px rgba(0,229,255,.2);
      --ff-head:'Bebas Neue',Impact,sans-serif;
      --ff-body:'Sora',sans-serif;
      --ff-mono:'JetBrains Mono',monospace;
      --ease:cubic-bezier(.16,1,.3,1);
    }
    html{scroll-behavior:smooth;font-size:16px}
    body{background:var(--bg);color:var(--white);font-family:var(--ff-body);font-weight:300;line-height:1.7;overflow-x:hidden}
    ::-webkit-scrollbar{width:4px}
    ::-webkit-scrollbar-track{background:var(--bg)}
    ::-webkit-scrollbar-thumb{background:var(--cyan);border-radius:2px}
    #bg-canvas{position:fixed;inset:0;z-index:0;pointer-events:none}
    .cursor-glow{position:fixed;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(0,229,255,.06) 0%,transparent 70%);pointer-events:none;z-index:1;transform:translate(-50%,-50%);transition:opacity .3s}
    .wrap{max-width:1100px;margin:0 auto;padding:0 2rem;position:relative;z-index:2}
    section{padding:6rem 0}
    .reveal{opacity:0;transform:translateY(40px);transition:opacity .8s var(--ease),transform .8s var(--ease)}
    .reveal.visible{opacity:1;transform:none}
    nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1.2rem 2rem;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid transparent;transition:all .4s}
    nav.scrolled{background:rgba(8,11,20,.88);border-color:var(--border);backdrop-filter:blur(20px)}
    .nav-logo{font-family:var(--ff-head);font-size:1.6rem;letter-spacing:.05em;color:var(--cyan);text-decoration:none}
    .nav-links{display:flex;gap:2rem;list-style:none}
    .nav-links a{color:var(--muted);text-decoration:none;font-size:.82rem;letter-spacing:.08em;text-transform:uppercase;font-weight:500;transition:color .3s}
    .nav-links a:hover{color:var(--cyan)}
    .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
    .hamburger span{width:22px;height:2px;background:var(--white);border-radius:2px;display:block;transition:.3s}
    .hamburger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
    .hamburger.open span:nth-child(2){opacity:0}
    .hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}
    .mobile-menu{display:none;position:fixed;inset:0;z-index:99;background:rgba(8,11,20,.97);backdrop-filter:blur(20px);flex-direction:column;align-items:center;justify-content:center;gap:2.5rem}
    .mobile-menu.open{display:flex}
    .mobile-menu a{font-family:var(--ff-head);font-size:3rem;color:var(--white);text-decoration:none;letter-spacing:.05em;transition:color .3s}
    .mobile-menu a:hover{color:var(--cyan)}
    #hero{min-height:100vh;display:flex;align-items:center;padding-top:5rem;position:relative}
    .hero-inner{position:relative;z-index:2}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--ff-mono);font-size:.78rem;color:var(--cyan);letter-spacing:.15em;text-transform:uppercase;margin-bottom:1.5rem;opacity:0;animation:fadeUp .6s var(--ease) .2s forwards}
    .hero-eyebrow::before{content:'';display:block;width:30px;height:1px;background:var(--cyan)}
    .hero-name{font-family:var(--ff-head);font-size:clamp(4rem,12vw,10rem);line-height:.9;letter-spacing:.02em;color:var(--white);opacity:0;animation:fadeUp .8s var(--ease) .4s forwards}
    .hero-name span{background:linear-gradient(135deg,var(--cyan) 0%,var(--violet) 50%,var(--pink) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hero-role{margin-top:1.5rem;font-size:clamp(1rem,2.5vw,1.3rem);color:var(--muted);font-weight:400;opacity:0;animation:fadeUp .8s var(--ease) .6s forwards}
    .hero-role .typed{color:var(--white);font-weight:500}
    .cursor-blink{display:inline-block;width:2px;height:1.1em;background:var(--cyan);margin-left:2px;animation:blink .7s infinite;vertical-align:text-bottom}
    .hero-desc{margin-top:1.5rem;max-width:520px;font-size:.95rem;color:var(--muted);line-height:1.8;opacity:0;animation:fadeUp .8s var(--ease) .8s forwards}
    .hero-desc strong{color:var(--white);font-weight:500}
    .hero-ctas{display:flex;gap:1rem;flex-wrap:wrap;margin-top:2.5rem;opacity:0;animation:fadeUp .8s var(--ease) 1s forwards}
    .btn{display:inline-flex;align-items:center;gap:.5rem;padding:.8rem 2rem;border-radius:4px;font-family:var(--ff-body);font-size:.85rem;font-weight:500;letter-spacing:.05em;text-transform:uppercase;text-decoration:none;cursor:pointer;border:none;transition:all .3s var(--ease)}
    .btn-primary{background:var(--cyan);color:var(--bg)}
    .btn-primary:hover{background:#33eeff;box-shadow:0 0 30px rgba(0,229,255,.4);transform:translateY(-2px)}
    .btn-outline{background:transparent;border:1px solid var(--border);color:var(--white)}
    .btn-outline:hover{border-color:var(--cyan);color:var(--cyan);box-shadow:var(--glow);transform:translateY(-2px)}
    .hero-socials{display:flex;gap:1.2rem;margin-top:3rem;opacity:0;animation:fadeUp .8s var(--ease) 1.2s forwards}
    .hero-socials a{display:flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:50%;border:1px solid var(--border);color:var(--muted);text-decoration:none;transition:all .3s}
    .hero-socials a:hover{border-color:var(--cyan);color:var(--cyan);box-shadow:var(--glow);transform:translateY(-3px)}
    .hero-scroll{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.5rem;opacity:0;animation:fadeUp .8s var(--ease) 1.6s forwards}
    .hero-scroll span{font-size:.7rem;letter-spacing:.15em;color:var(--muted);text-transform:uppercase}
    .scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--cyan),transparent);animation:scrollPulse 2s infinite}
    .section-label{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--ff-mono);font-size:.73rem;color:var(--cyan);letter-spacing:.2em;text-transform:uppercase;margin-bottom:.8rem}
    .section-label::before{content:'';display:block;width:20px;height:1px;background:var(--cyan)}
    .section-title{font-family:var(--ff-head);font-size:clamp(2.5rem,6vw,4.5rem);line-height:.95;letter-spacing:.02em;color:var(--white);margin-bottom:3rem}
    .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start}
    .about-text p{color:var(--muted);line-height:1.9;margin-bottom:1.2rem;font-size:.95rem}
    .about-text p strong{color:var(--white);font-weight:600}
    .about-text .highlight{color:var(--cyan);font-weight:500}
    .about-stats{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem}
    .stat-card{background:var(--card-bg);border:1px solid var(--border);border-radius:8px;padding:1.5rem;position:relative;overflow:hidden;transition:border-color .3s,box-shadow .3s}
    .stat-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,229,255,.05),transparent);opacity:0;transition:opacity .3s}
    .stat-card:hover{border-color:var(--cyan);box-shadow:var(--glow)}
    .stat-card:hover::before{opacity:1}
    .stat-number{font-family:var(--ff-head);font-size:3rem;color:var(--cyan);line-height:1;margin-bottom:.3rem}
    .stat-label{font-size:.78rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}
    #skills{background:var(--bg2)}
    .skills-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
    .skill-group{background:var(--card-bg);border:1px solid var(--border);border-radius:10px;padding:1.8rem;backdrop-filter:blur(10px);transition:border-color .3s,transform .3s,box-shadow .3s}
    .skill-group:hover{border-color:var(--cyan);transform:translateY(-5px);box-shadow:var(--glow)}
    .skill-group-icon{font-size:1.8rem;margin-bottom:1rem}
    .skill-group-title{font-family:var(--ff-mono);font-size:.73rem;color:var(--cyan);letter-spacing:.15em;text-transform:uppercase;margin-bottom:1rem}
    .skill-tags{display:flex;flex-wrap:wrap;gap:.5rem}
    .skill-tag{padding:.3rem .8rem;border-radius:3px;background:rgba(0,229,255,.06);border:1px solid rgba(0,229,255,.15);font-size:.77rem;color:var(--white);font-family:var(--ff-mono);transition:background .3s,border-color .3s,color .3s}
    .skill-tag:hover{background:rgba(0,229,255,.15);border-color:var(--cyan);color:var(--cyan)}
    /* EXPERIENCE */
    #experience{background:var(--bg3)}
    .exp-card{background:var(--card-bg);border:1px solid var(--border);border-radius:12px;padding:2.2rem 2.5rem;position:relative;overflow:hidden;backdrop-filter:blur(10px);transition:border-color .4s,box-shadow .4s,transform .4s var(--ease);max-width:800px}
    .exp-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--cyan),var(--violet),var(--pink));transform:scaleX(0);transform-origin:left;transition:transform .5s var(--ease)}
    .exp-card:hover{border-color:rgba(0,229,255,.35);transform:translateY(-5px);box-shadow:0 24px 60px rgba(0,0,0,.45),var(--glow)}
    .exp-card:hover::before{transform:scaleX(1)}
    .exp-header{display:flex;align-items:flex-start;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;margin-bottom:1.6rem}
    .exp-left{display:flex;align-items:center;gap:1.2rem}
    .exp-logo{width:52px;height:52px;border-radius:12px;background:linear-gradient(135deg,rgba(0,229,255,.1),rgba(124,58,237,.2));border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0}
    .exp-company{font-family:var(--ff-head);font-size:1.8rem;color:var(--white);letter-spacing:.03em;line-height:1}
    .exp-type{font-family:var(--ff-mono);font-size:.7rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-top:.3rem}
    .exp-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.4rem 1rem;border-radius:20px;background:rgba(0,229,255,.08);border:1px solid rgba(0,229,255,.2);font-family:var(--ff-mono);font-size:.7rem;color:var(--cyan);letter-spacing:.08em;white-space:nowrap;flex-shrink:0}
    .exp-dot{width:6px;height:6px;border-radius:50%;background:var(--cyan);animation:pulseDot 2s infinite;flex-shrink:0}
    .exp-role{font-size:1.05rem;font-weight:600;color:var(--white);margin-bottom:.4rem}
    .exp-duration{font-family:var(--ff-mono);font-size:.75rem;color:var(--muted);margin-bottom:1.3rem;display:flex;align-items:center;gap:.5rem}
    .exp-duration::before{content:'';display:block;width:14px;height:1px;background:var(--muted)}
    .exp-desc{font-size:.9rem;color:var(--muted);line-height:1.9;margin-bottom:1.5rem}
    .exp-desc strong{color:var(--white);font-weight:500}
    .exp-skills{display:flex;flex-wrap:wrap;gap:.5rem}
    .exp-skill{padding:.28rem .75rem;border-radius:3px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.25);font-size:.75rem;color:#a78bfa;font-family:var(--ff-mono)}
    .exp-meta{font-family:var(--ff-mono);font-size:.68rem;color:rgba(107,122,153,.38);margin-top:1.3rem;padding-top:1rem;border-top:1px solid rgba(0,229,255,.06);letter-spacing:.06em}
    .projects-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem}
    .project-card{background:var(--card-bg);border:1px solid var(--border);border-radius:12px;padding:2rem;position:relative;overflow:hidden;backdrop-filter:blur(10px);transition:border-color .3s,transform .4s var(--ease),box-shadow .3s}
    .project-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--cyan),var(--violet));transform:scaleX(0);transform-origin:left;transition:transform .4s var(--ease)}
    .project-card:hover{border-color:rgba(0,229,255,.3);transform:translateY(-6px);box-shadow:0 20px 60px rgba(0,0,0,.4)}
    .project-card:hover::before{transform:scaleX(1)}
    .project-num{font-family:var(--ff-head);font-size:4rem;color:rgba(0,229,255,.07);line-height:1;position:absolute;top:1rem;right:1.5rem;user-select:none}
    .project-date{font-family:var(--ff-mono);font-size:.72rem;color:var(--cyan);letter-spacing:.12em;text-transform:uppercase;margin-bottom:.8rem}
    .project-title{font-family:var(--ff-head);font-size:1.8rem;color:var(--white);margin-bottom:1rem;letter-spacing:.02em}
    .project-desc{font-size:.88rem;color:var(--muted);line-height:1.8;margin-bottom:1.5rem}
    .project-tech{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.5rem}
    .tech-badge{padding:.25rem .7rem;border-radius:3px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.25);font-size:.75rem;color:#a78bfa;font-family:var(--ff-mono)}
    .project-link{display:inline-flex;align-items:center;gap:.4rem;font-size:.8rem;color:var(--cyan);text-decoration:none;font-family:var(--ff-mono);letter-spacing:.05em;transition:gap .3s}
    .project-link:hover{gap:.8rem}
    .project-link .arrow{transition:transform .3s}
    .project-link:hover .arrow{transform:translateX(4px)}
    #edu{background:var(--bg2)}
    .edu-cert-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem}
    .timeline{position:relative}
    .timeline-item{position:relative;padding-left:1.8rem;margin-bottom:2rem}
    .timeline-item::before{content:'';position:absolute;left:0;top:6px;width:10px;height:10px;border-radius:50%;background:var(--cyan);box-shadow:0 0 10px var(--cyan)}
    .timeline-item::after{content:'';position:absolute;left:4px;top:16px;width:1px;height:calc(100% + .5rem);background:linear-gradient(to bottom,var(--border),transparent)}
    .timeline-item:last-child::after{display:none}
    .timeline-year{font-family:var(--ff-mono);font-size:.72rem;color:var(--cyan);letter-spacing:.1em;margin-bottom:.3rem}
    .timeline-title{font-size:1rem;font-weight:600;color:var(--white);margin-bottom:.2rem}
    .timeline-sub{font-size:.85rem;color:var(--muted)}
    .cert-list{display:flex;flex-direction:column;gap:1rem}
    .cert-item{display:flex;align-items:flex-start;gap:1rem;background:var(--card-bg);border:1px solid var(--border);border-radius:8px;padding:1.2rem;transition:border-color .3s,box-shadow .3s}
    .cert-item:hover{border-color:var(--cyan);box-shadow:var(--glow)}
    .cert-icon{flex-shrink:0;width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1rem}
    .cert-name{font-size:.9rem;font-weight:500;color:var(--white)}
    .cert-issuer{font-size:.78rem;color:var(--muted);margin-top:.2rem}
    #contact{text-align:center;position:relative}
    .contact-glow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:400px;background:radial-gradient(ellipse,rgba(124,58,237,.08) 0%,transparent 70%);pointer-events:none}
    .contact-email{display:inline-block;font-family:var(--ff-head);font-size:clamp(1.5rem,4vw,3rem);color:var(--white);text-decoration:none;letter-spacing:.03em;margin-bottom:2.5rem;transition:color .3s}
    .contact-email:hover{color:var(--cyan)}
    .contact-links{display:flex;justify-content:center;gap:1.5rem;flex-wrap:wrap}
    .contact-link{display:inline-flex;align-items:center;gap:.6rem;padding:.7rem 1.5rem;border-radius:4px;border:1px solid var(--border);color:var(--muted);text-decoration:none;font-size:.82rem;font-family:var(--ff-mono);letter-spacing:.05em;transition:all .3s}
    .contact-link:hover{border-color:var(--cyan);color:var(--cyan);box-shadow:var(--glow)}
    footer{border-top:1px solid var(--border);padding:2rem;text-align:center;font-size:.78rem;color:var(--muted);font-family:var(--ff-mono);position:relative;z-index:2}
    footer span{color:var(--cyan)}
    @keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:none}}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
    @keyframes scrollPulse{0%,100%{opacity:.3}50%{opacity:1}}
    @keyframes pulseDot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.65)}}
    @media(max-width:900px){
      .about-grid,.edu-cert-grid{grid-template-columns:1fr;gap:3rem}
      .skills-grid{grid-template-columns:1fr 1fr}
      .projects-grid{grid-template-columns:1fr}
      .exp-header{flex-direction:column;gap:.8rem}
    }
    @media(max-width:600px){
      .nav-links{display:none}
      .hamburger{display:flex}
      .skills-grid{grid-template-columns:1fr}
      .about-stats{grid-template-columns:1fr 1fr}
      .hero-ctas{flex-direction:column;align-items:flex-start}
      .exp-card{padding:1.5rem 1.3rem}
    }
  </style>
</head>
<body>
<div class="cursor-glow" id="cursorGlow"></div>
<canvas id="bg-canvas"></canvas>

<nav id="nav">
  <a href="#hero" class="nav-logo">DK</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#edu">Education</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <button class="hamburger" id="hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>
<div class="mobile-menu" id="mobileMenu">
  <a href="#about" onclick="closeMobile()">About</a>
  <a href="#skills" onclick="closeMobile()">Skills</a>
  <a href="#experience" onclick="closeMobile()">Experience</a>
  <a href="#projects" onclick="closeMobile()">Projects</a>
  <a href="#edu" onclick="closeMobile()">Education</a>
  <a href="#contact" onclick="closeMobile()">Contact</a>
</div>

<section id="hero">
  <div class="wrap">
    <div class="hero-inner">
      <div class="hero-eyebrow">BCA Student &amp; Developer</div>
      <h1 class="hero-name">Darshana <span>K</span></h1>
      <p class="hero-role">I build &nbsp;<span class="typed" id="typed-text"></span><span class="cursor-blink"></span></p>
      <p class="hero-desc">Motivated <strong>BCA student at NITTE University</strong> specialising in <strong>cloud technology</strong> and full-stack development. Passionate about building elegant, useful solutions.</p>
      <div class="hero-ctas">
        <a href="#projects" class="btn btn-primary">View Projects</a>
        <a href="#contact" class="btn btn-outline">Get In Touch</a>
      </div>
      <div class="hero-socials">
        <a href="https://www.linkedin.com/in/darshana-k-687775349/" target="_blank" title="LinkedIn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="https://github.com/Darshanak11" target="_blank" title="GitHub">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
