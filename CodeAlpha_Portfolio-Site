<script>
  const nav=document.getElementById('nav');
  window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>40));
  const hbg=document.getElementById('hamburger'),mm=document.getElementById('mobileMenu');
  hbg.addEventListener('click',()=>{hbg.classList.toggle('open');mm.classList.toggle('open')});
  function closeMobile(){hbg.classList.remove('open');mm.classList.remove('open')}
  const glow=document.getElementById('cursorGlow');
  document.addEventListener('mousemove',e=>{glow.style.left=e.clientX+'px';glow.style.top=e.clientY+'px'});
  const obs=new IntersectionObserver(entries=>{
    entries.forEach((e,i)=>{if(e.isIntersecting)setTimeout(()=>e.target.classList.add('visible'),i*120)});
  },{threshold:0.1});
  document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
  const phrases=['web applications.','Python tools.','clean UI & UX.','cloud solutions.','.NET MVC systems.','frontend experiences.'];
  let pi=0,ci=0,del=false;
  const tel=document.getElementById('typed-text');
  function type(){
    const p=phrases[pi];
    if(!del){tel.textContent=p.slice(0,++ci);if(ci===p.length){del=true;setTimeout(type,1800);return}}
    else{tel.textContent=p.slice(0,--ci);if(ci===0){del=false;pi=(pi+1)%phrases.length}}
    setTimeout(type,del?42:85);
  }
  type();
  const cv=document.getElementById('bg-canvas'),cx=cv.getContext('2d');
  let W,H,dots=[],mx=-999,my=-999;
  const COLS=22,ROWS=12,MD=140;
  function resize(){
    W=cv.width=innerWidth;H=cv.height=innerHeight;dots=[];
    const sx=W/COLS,sy=H/ROWS;
    for(let r=0;r<=ROWS;r++)for(let c=0;c<=COLS;c++)dots.push({x:c*sx,y:r*sy,ox:c*sx,oy:r*sy});
  }
  window.addEventListener('resize',resize);
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});
  resize();
  function draw(){
    cx.clearRect(0,0,W,H);
    dots.forEach(d=>{
      const dx=mx-d.ox,dy=my-d.oy,dist=Math.hypot(dx,dy);
      if(dist<MD){const f=(MD-dist)/MD;d.x=d.ox-dx*f*.18;d.y=d.oy-dy*f*.18}
      else{d.x+=(d.ox-d.x)*.1;d.y+=(d.oy-d.y)*.1}
    });
    const C1=COLS+1;
    cx.strokeStyle='rgba(0,229,255,0.035)';cx.lineWidth=1;
    for(let r=0;r<=ROWS;r++){cx.beginPath();for(let c=0;c<=COLS;c++){const d=dots[r*C1+c];c?cx.lineTo(d.x,d.y):cx.moveTo(d.x,d.y)}cx.stroke()}
    for(let c=0;c<=COLS;c++){cx.beginPath();for(let r=0;r<=ROWS;r++){const d=dots[r*C1+c];r?cx.lineTo(d.x,d.y):cx.moveTo(d.x,d.y)}cx.stroke()}
    dots.forEach(d=>{
      const dist=Math.hypot(mx-d.x,my-d.y);
      const a=dist<MD?.12+.3*(MD-dist)/MD:.05,r=dist<MD?1.6:.8;
      cx.beginPath();cx.arc(d.x,d.y,r,0,Math.PI*2);
      cx.fillStyle=`rgba(0,229,255,${a})`;cx.fill();
    });
    requestAnimationFrame(draw);
  }
  draw();
</script>
